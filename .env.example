# Apple Store Connect API Configuration
APPLE_KEY_ID=your_key_id_here
APPLE_ISSUER_ID=your_issuer_id_here

# Apple Store Connect API Private Key (keep this secure!)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your_private_key_content_here
-----END PRIVATE KEY-----"

# Server Configuration
PORT=3992
HOST=0.0.0.0
CORS_ORIGIN=*

# OAuth Settings (optional — leave false for open local /mcp)
OAUTH_ENABLED=false
